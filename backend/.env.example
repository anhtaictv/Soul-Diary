# =============================================
# Nhật Ký Cảm Xúc Số — Environment Variables
# Đổi tên file này thành .env trước khi chạy
# =============================================

# Server
PORT=3001
NODE_ENV=development

# JWT — đổi thành chuỗi random dài ít nhất 32 ký tự
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Microsoft SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your_db_password
DB_NAME=NhatKyCamXuc
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5500
